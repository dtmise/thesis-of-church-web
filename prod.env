export API_JWT_SECRET=test_secret_key_for_jwt_token_generation_1234567890
export API_PORT=1904
export API_DB_HOST=localhost
export API_DB_PORT=5432
export API_DB_USER=thesis_prod
export API_DB_NAME=thesis_prod
export API_DB_PASSWORD=test_password_for_database_1234567890
export WEB_PORT=3000
export REDIRECT_PORT=8080
export NODE_ENV=test
export CRT_PATH=/etc/ssl/certs/computable.tech.crt # если возможно, то запустим без сертификата, иначе нужно будет создать самоподписанный сертификат и указать путь к нему
export KEY_PATH=/etc/ssl/private/computable.tech.key # если возможно, то запустим без сертификата, иначе нужно будет создать самоподписанный сертификат и указать путь к нему
